# --- Required ---
PORT=3000
NODE_ENV=development

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

INTERNAL_SERVICE_SECRET=your-internal-secret
INTERNAL_SERVICE_SECRET_PREVIOUS=

# Optional dedicated secret for machine cron (POST `/internal/cron/reconcile-procurement-declared-stock`, header `X-Internal-Secret`).
# When unset, `INTERNAL_SERVICE_SECRET` is accepted instead.
# This route always runs a live reconcile (declares stock on providers). Request body `dry_run` is ignored.
# PROCUREMENT_DECLARED_STOCK_CRON_SECRET=

# Same secret Edge Functions use for outbound provider traffic. Required when
# `provider_accounts.api_profile.base_url` / `base_url_v2` point at the EC2
# Bamboo proxy — without it, quote/checkout returns 401 from the proxy even
# with valid Basic auth (see Edge `buildProviderProxyHeaders`).
PROVIDER_PROXY_SHARED_SECRET=

# Fallback when Vault RPC cannot resolve secrets (local dev): match names in
# `provider_secrets_ref` for the Bamboo provider account.
# BAMBOO_CLIENT_ID=
# BAMBOO_CLIENT_SECRET=

# Manual procurement only (LootCodes-Api-Admin): call Bamboo directly at
# api.bamboocardportal.com instead of `api_profile.base_url` / `base_url_v2`
# (e.g. EC2 proxy). Set to true when proxy/HMAC is not used.
# BAMBOO_FORCE_PUBLIC_API=true
# Optional overrides (defaults: official integration v1/v2 paths):
# BAMBOO_PUBLIC_BASE_URL_V1=
# BAMBOO_PUBLIC_BASE_URL_V2=

# --- Optional (features degrade gracefully) ---
CORS_ORIGINS=https://lootcodes.com,https://www.lootcodes.com
SITE_URL=https://lootcodes.com
SITE_NAME=LootCodes

SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=

# Build-time Sentry sourcemap upload
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Algolia (admin stats/sync)
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_KEY=
ALGOLIA_INDEX_NAME=products

# Encryption (key decryption — same values as Edge Function secrets)
ENCRYPTION_MASTER_KEY=
ENCRYPTION_MASTER_KEY_ID=
ENCRYPTION_MASTER_KEY_LEGACY=

# Stripe (refunds)
STRIPE_SECRET_KEY=

# Eneba seller/GraphQL: optional overrides when `provider_accounts.api_profile`
# still points at a broken EC2 proxy (fixes OAuth 401 Invalid signature).
# If unset, HTTP+amazonaws or ec2-*.compute-*.amazonaws.com in api_profile is
# replaced at bootstrap with the official hosts below.
# ENEBA_GRAPHQL_BASE_URL=https://api.eneba.com
# ENEBA_OAUTH_TOKEN_URL=https://user.eneba.com/oauth/token
